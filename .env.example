# OpenAI 兼容 API（必填）
OPENAI_API_KEY=sk-your-key-here

# 可选：网关/代理 Base URL（例如兼容端点）
# OPENAI_BASE_URL=https://api.openai.com/v1

# v2 全文原子核心词
# 未设时回退：MEMOK_ARTICLE_LLM_MODEL -> MEMOK_SENTENCE_CORE_LLM_MODEL -> MEMOK_SEGMENT_CORE_LLM_MODEL -> gpt-4o-mini
# MEMOK_V2_ARTICLE_CORE_WORDS_LLM_MODEL=gpt-4o-mini

# v2 核心词同义归一
# 未设时回退：MEMOK_CORE_WORDS_NORMALIZE_LLM_MODEL -> MEMOK_SENTENCE_MERGE_LLM_MODEL -> ... -> MEMOK_ARTICLE_LLM_MODEL
# MEMOK_V2_ARTICLE_CORE_WORDS_NORMALIZE_LLM_MODEL=gpt-4o-mini

# v2 整篇记忆句
# 未设时回退：MEMOK_SENTENCE_DEDUCE_LLM_MODEL -> MEMOK_ARTICLE_LLM_MODEL -> ...
# MEMOK_V2_ARTICLE_SENTENCES_LLM_MODEL=gpt-4o-mini

# 可选：v2 article-sentences 输出 token 预算（默认 8192）
# MEMOK_V2_ARTICLE_SENTENCES_MAX_OUTPUT_TOKENS=8192

# 兼容回退链（建议一起保留，便于与旧 .env 兼容）
MEMOK_ARTICLE_LLM_MODEL=gpt-4o-mini
MEMOK_SEGMENT_CORE_LLM_MODEL=gpt-4o-mini
MEMOK_SENTENCE_PROCESS_LLM_MODEL=gpt-4o-mini
MEMOK_SENTENCE_CORE_LLM_MODEL=gpt-4o-mini
MEMOK_SENTENCE_DEDUCE_LLM_MODEL=gpt-4o-mini
MEMOK_SENTENCE_MERGE_LLM_MODEL=gpt-4o-mini
MEMOK_CORE_WORDS_NORMALIZE_LLM_MODEL=gpt-4o-mini

# 可选：core-words-normalize 输出 token 预算（默认 32768，DeepSeek 分支会 cap 到 8192）
# MEMOK_CORE_WORDS_NORMALIZE_MAX_OUTPUT_TOKENS=8192

# 可选：强制跳过 structured parse，仅使用 json_object
# MEMOK_SKIP_LLM_STRUCTURED_PARSE=1

# 可选：LLM 请求并发（<=1 等同串行；上限 64）
# MEMOK_LLM_MAX_WORKERS=4
