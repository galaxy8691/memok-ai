# OpenAI 兼容 API（必填）
# 若通过 OpenClaw 插件配置填写 llmApiKey / llmModel 等，且进程内未设置下列变量，插件启动时会自动补齐（与 CLI 共用同一套 env 名）。
OPENAI_API_KEY=sk-your-key-here

# 可选：网关/代理 Base URL（例如兼容端点）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 默认 LLM 模型：整篇流水线各阶段共用（除非设置 MEMOK_V2_*_LLM_MODEL 等覆盖项，见源码 resolveModel）
MEMOK_LLM_MODEL=gpt-4o-mini

# 可选：`npm run dev -- dream --db …` 专用模型；未设时沿用 MEMOK_LLM_MODEL
# MEMOK_DREAMING_LLM_MODEL=gpt-4o-mini

# 可选：记忆句阶段最大输出 token（默认 8192）
# MEMOK_V2_ARTICLE_SENTENCES_MAX_OUTPUT_TOKENS=8192

# 可选：归一阶段最大输出 token（默认 32768；DeepSeek 等会 cap）
# MEMOK_CORE_WORDS_NORMALIZE_MAX_OUTPUT_TOKENS=8192

# 可选：强制跳过 structured parse，仅使用 json_object
# MEMOK_SKIP_LLM_STRUCTURED_PARSE=1

# 可选：LLM 请求并发（<=1 等同串行；上限 64）
# MEMOK_LLM_MAX_WORKERS=4
