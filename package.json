{
  "name": "memok-ai",
  "version": "0.3.0",
  "description": "Node/TS implementation of memok v2 pipeline",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "ci": "npm run lint && npm run build && npm run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "memok-ai contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galaxy8691/memok-ai.git"
  },
  "bugs": {
    "url": "https://github.com/galaxy8691/memok-ai/issues"
  },
  "homepage": "https://github.com/galaxy8691/memok-ai#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
