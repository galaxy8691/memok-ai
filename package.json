{
  "name": "memok-ai",
  "version": "0.1.4",
  "description": "Node/TS implementation of memok v2 pipeline",
  "main": "dist/index.js",
  "bin": {
    "memok-ai": "dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "ci": "npm run lint && npm run build && npm run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "batch": "tsx src/scripts/runArticlesBatch.ts",
    "import:outputs": "tsx src/scripts/importOutputsToSqlite.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
